# Shared runtime variables
APP_ENV=development
ALLOW_LOCAL_DEV_DATABASE=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/sustainability
REDIS_URL=redis://127.0.0.1:6379/0
AZURE_OPENAI_ENDPOINT=https://example-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-local-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Web public variables
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_DEFAULT_TENANT_ID=
NEXT_PUBLIC_DEFAULT_PROJECT_ID=

# API-only variables
API_PREFIX=
API_VERSION=v1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ARQ_QUEUE_NAME=arq:queue
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_RAW=raw-documents
AZURE_STORAGE_CONTAINER_PARSED=parsed-documents
AZURE_STORAGE_CONTAINER_ARTIFACTS=report-artifacts
AZURE_STORAGE_USE_LOCAL=true
LOCAL_BLOB_ROOT=apps/api/storage
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_INDEX_NAME=esg-evidence-index
AZURE_AI_SEARCH_USE_LOCAL=true
LOCAL_SEARCH_INDEX_ROOT=apps/api/storage/search-index
LOCAL_CHECKPOINT_ROOT=apps/api/storage/checkpoints
WORKFLOW_RETRY_MAX_PER_NODE=2
WORKFLOW_RETRY_BASE_SECONDS=2
WORKFLOW_RETRY_MAX_DEFER_SECONDS=30
WORKFLOW_EXECUTE_MAX_STEPS=64
AZURE_OPENAI_IMAGE_DEPLOYMENT=
AZURE_OPENAI_IMAGE_FALLBACK_DEPLOYMENT=
VERIFIER_MODE=heuristic
VERIFIER_PASS_THRESHOLD=0.55
VERIFIER_UNSURE_THRESHOLD=0.3
REPORT_FACTORY_DEFAULT_BLUEPRINT_VERSION=brandable-tr-v1
REPORT_FACTORY_DEFAULT_LOCALE=tr-TR

# Worker-only variables
WORKER_CONCURRENCY=4
QUEUE_NAME=arq:queue
OCR_JOB_MAX_RETRIES=3
OCR_RETRY_BASE_SECONDS=2
OCR_RETRY_MAX_DEFER_SECONDS=30
INDEX_JOB_MAX_RETRIES=3
INDEX_RETRY_BASE_SECONDS=2
INDEX_RETRY_MAX_DEFER_SECONDS=30
PACKAGE_JOB_MAX_RETRIES=2
PACKAGE_RETRY_BASE_SECONDS=5
PACKAGE_RETRY_MAX_DEFER_SECONDS=60

# Playwright and local dev helpers
PLAYWRIGHT_WEB_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_API_BASE_URL=http://127.0.0.1:8000
PLAYWRIGHT_DEMO_TENANT_ID=
PLAYWRIGHT_DEMO_PROJECT_ID=
